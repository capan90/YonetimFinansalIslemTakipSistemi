<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Cargo.QuickUpdateStatusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Durum Değiştir"
        SizeToContent="Height" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="16">
        <TextBlock Text="Mevcut Durum:" FontWeight="SemiBold" Margin="0,0,0,2"/>
        <TextBlock x:Name="CurrentStatusText" Margin="0,0,0,12" Foreground="#555555"/>

        <TextBlock Text="Yeni Durum:" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="NewStatusCombo"
                  DisplayMemberPath="Display"
                  SelectedValuePath="Value"
                  Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Güncelle" IsDefault="True" Width="80" Margin="0,0,8,0"
                    Click="UpdateButton_Click"/>
            <Button Content="İptal" IsCancel="True" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>
