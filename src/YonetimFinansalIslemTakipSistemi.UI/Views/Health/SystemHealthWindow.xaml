<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Health.SystemHealthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Sistem Sağlığı"
        Width="720" Height="660"
        MinWidth="580" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Satır şablonu: Etiket | Değer | Durum -->
        <DataTemplate x:Key="RowTemplate">
            <Grid Margin="2,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="65"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Label}"
                           Foreground="#555"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Value}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Value}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <!-- GroupBox başlık stili -->
        <Style x:Key="SectionBox" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10,6,10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Section içindeki ItemsControl -->
        <Style x:Key="SectionItems" TargetType="ItemsControl">
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- İçerik alanı -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12,10,12,4">
            <StackPanel>

                <!-- Genel Durum Bandı -->
                <Border x:Name="StatusBanner"
                        CornerRadius="4"
                        Padding="14,10"
                        Margin="0,0,0,10"
                        Background="#888">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusLabel"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Text="Kontrol ediliyor..."/>
                            <TextBlock x:Name="CheckedAtLabel"
                                       FontSize="11"
                                       Foreground="White"
                                       Opacity="0.9"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   x:Name="OverallStatusIcon"
                                   FontSize="28"
                                   Foreground="White"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"
                                   Text="●"/>
                    </Grid>
                </Border>

                <!-- Uygulama -->
                <GroupBox Header="Uygulama" Style="{StaticResource SectionBox}">
                    <ItemsControl x:Name="AppSection"
                                  Style="{StaticResource SectionItems}"
                                  ItemTemplate="{StaticResource RowTemplate}"/>
                </GroupBox>

                <!-- Veritabanı -->
                <GroupBox Header="Veritabanı" Style="{StaticResource SectionBox}">
                    <ItemsControl x:Name="DbSection"
                                  Style="{StaticResource SectionItems}"
                                  ItemTemplate="{StaticResource RowTemplate}"/>
                </GroupBox>

                <!-- Loglar -->
                <GroupBox Header="Loglar" Style="{StaticResource SectionBox}">
                    <ItemsControl x:Name="LogSection"
                                  Style="{StaticResource SectionItems}"
                                  ItemTemplate="{StaticResource RowTemplate}"/>
                </GroupBox>

                <!-- Yedekleme -->
                <GroupBox Header="Yedekleme" Style="{StaticResource SectionBox}">
                    <ItemsControl x:Name="BackupSection"
                                  Style="{StaticResource SectionItems}"
                                  ItemTemplate="{StaticResource RowTemplate}"/>
                </GroupBox>

                <!-- Güncelleme -->
                <GroupBox Header="Güncelleme" Style="{StaticResource SectionBox}">
                    <ItemsControl x:Name="UpdateSection"
                                  Style="{StaticResource SectionItems}"
                                  ItemTemplate="{StaticResource RowTemplate}"/>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Alt buton çubuğu -->
        <Border Grid.Row="1"
                BorderBrush="#DDD"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <DockPanel>
                <Button x:Name="BtnRefresh"
                        Content="Yenile"
                        Width="80"
                        DockPanel.Dock="Left"
                        Click="Refresh_Click"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <Button Content="Log Klasörü"
                            Width="100"
                            Margin="0,0,6,0"
                            Click="OpenLog_Click"/>
                    <Button Content="Backup Klasörü"
                            Width="110"
                            Margin="0,0,6,0"
                            Click="OpenBackup_Click"/>
                    <Button Content="Publish Klasörü"
                            Width="115"
                            Click="OpenPublish_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
