<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Permissions.UserPermissionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yetki Yönetimi"
        Height="580" Width="480"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">

    <DockPanel Margin="16">

        <!-- Kullanıcı seçimi -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Kullanıcı:" VerticalAlignment="Center" Width="80"/>
            <ComboBox Width="260"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      DisplayMemberPath="FullName"/>
        </StackPanel>

        <!-- Kaydet butonu -->
        <Button DockPanel.Dock="Bottom"
                Content="Kaydet"
                Width="100" HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Command="{Binding SaveCommand}"/>

        <!-- Yetki listesi -->
        <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="12">
            <ItemsControl ItemsSource="{Binding Perms}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Label}"
                                  IsChecked="{Binding IsGranted}"
                                  Margin="0,4,0,4"
                                  FontSize="13"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

    </DockPanel>
</Window>
