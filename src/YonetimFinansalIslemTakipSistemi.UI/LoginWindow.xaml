<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Giriş Yap"
        Height="560" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/AppIcon.ico">

    <Border Background="{DynamicResource Theme.Surface}">
        <StackPanel Margin="36,24">

            <!-- Logo -->
            <Image x:Name="AppLogo"
                   Height="140" Width="260"
                   Margin="0,0,0,16"
                   HorizontalAlignment="Center"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Ana başlık -->
            <TextBlock Text="Yönetim Finansal İşlem Takip Sistemi"
                       FontSize="14" FontWeight="Bold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Theme.Text}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>

            <!-- Hoş geldiniz -->
            <TextBlock Text="Hoş geldiniz"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Theme.Primary}"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,2"/>

            <TextBlock Text="Lütfen hesabınızla giriş yapın."
                       FontSize="11"
                       Foreground="{DynamicResource Theme.MutedText}"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Kullanıcı adı alanı — icon + placeholder + input -->
            <Border x:Name="UserNameBorder"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1" CornerRadius="4"
                    Background="{DynamicResource Theme.InputBackground}"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="👤"
                               FontFamily="Segoe UI Emoji"
                               FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource Theme.MutedText}"/>
                    <TextBox x:Name="UserNameBox"
                             Grid.Column="1"
                             Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Padding="4,7"
                             Background="Transparent"
                             Foreground="{DynamicResource Theme.Text}"
                             VerticalContentAlignment="Center"/>
                    <!-- Placeholder -->
                    <TextBlock Grid.Column="1"
                               x:Name="UserNamePlaceholder"
                               Text="Lütfen kullanıcı adınızı giriniz..."
                               IsHitTestVisible="False"
                               Padding="4,7" VerticalAlignment="Center"
                               Foreground="{DynamicResource Theme.MutedText}"
                               FontSize="12"
                               Visibility="Visible">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <!-- Kullanıcı adı girilince placeholder gizlenir -->
                                    <DataTrigger Binding="{Binding UserName}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Şifre alanı — icon + placeholder + input -->
            <Border x:Name="PasswordBorder"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1" CornerRadius="4"
                    Background="{DynamicResource Theme.InputBackground}"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="🔒"
                               FontFamily="Segoe UI Emoji"
                               FontSize="13"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource Theme.MutedText}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Column="1"
                                 BorderThickness="0" Padding="4,7"
                                 Background="Transparent"
                                 Foreground="{DynamicResource Theme.Text}"
                                 VerticalContentAlignment="Center"/>
                    <!-- Placeholder — code-behind ile kontrol edilir -->
                    <TextBlock x:Name="PasswordPlaceholder"
                               Grid.Column="1"
                               Text="Lütfen şifrenizi giriniz..."
                               IsHitTestVisible="False"
                               Padding="4,7" VerticalAlignment="Center"
                               Foreground="{DynamicResource Theme.MutedText}"
                               FontSize="12"
                               Visibility="Visible"/>
                </Grid>
            </Border>

            <!-- Hata mesajı — Sprint 12'den korunan pattern -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#DC2626"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Giriş butonu -->
            <Button Content="Giriş Yap"
                    Command="{Binding LoginCommand}"
                    IsDefault="True"
                    HorizontalAlignment="Stretch"
                    Padding="8,8"
                    FontWeight="SemiBold"
                    FontSize="13"
                    Margin="0,2,0,16"
                    Style="{StaticResource PrimaryButton}"/>

            <!-- Alt footer -->
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="VersionText"
                           Text="Versiyon: 1.0.0.0"
                           FontSize="10"
                           Foreground="{DynamicResource Theme.MutedText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,2"/>
                <TextBlock Text="© Erdemsoft Tekstil A.Ş."
                           FontSize="10"
                           Foreground="{DynamicResource Theme.MutedText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
