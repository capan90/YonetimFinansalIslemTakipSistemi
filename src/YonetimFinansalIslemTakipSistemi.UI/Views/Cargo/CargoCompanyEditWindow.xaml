<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Cargo.CargoCompanyEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="16">

        <Label Content="Firma Adı *:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Content="Takip Linki Şablonu:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding TrackingUrlTemplate, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Takip numarasının geleceği yere {0} yazılır. Örn: https://kargo.com/takip/{0}"
                 Margin="0,0,0,2"/>
        <TextBlock Text="Takip numarasının geleceği yere {0} yazılır. Örn: https://kargo.com/takip/{0}"
                   FontSize="10" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Label Content="Telefon:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="20"
                 PreviewTextInput="PhoneTextBox_PreviewTextInput"
                 ToolTip="Rakam, boşluk ve +, -, (, ) karakterleri; en fazla 20 karakter"
                 Margin="0,0,0,8"/>

        <Label Content="Website:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Website, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Content="Notlar:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                 Height="48" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,8"/>

        <CheckBox Content="Aktif" IsChecked="{Binding IsActive}" Margin="0,0,0,12"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Kaydet" Command="{Binding SaveCommand}" IsDefault="True" Width="80" Margin="0,0,8,0"/>
            <Button Content="İptal"  IsCancel="True" Width="80" Click="CancelButton_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
