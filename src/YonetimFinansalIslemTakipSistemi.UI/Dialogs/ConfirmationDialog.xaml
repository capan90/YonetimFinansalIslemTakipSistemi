<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Dialogs.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="Height"
        Width="420"
        MinWidth="300"
        MaxWidth="520"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık bandı -->
        <Border Grid.Row="0" Background="#5D6D7E">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="?"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBlock Text="{Binding HeaderTitle}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Mesaj -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Message}"
                   TextWrapping="Wrap"
                   Margin="20,16,20,12"
                   FontSize="13"
                   Foreground="#222222"
                   LineHeight="20"/>

        <!-- Alt bölüm: Evet / Hayır -->
        <Border Grid.Row="2"
                Background="#F5F5F5"
                BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,14,10">
                <Button Content="Evet"
                        Width="80" Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="YesButton_Click"/>
                <Button Content="Hayır"
                        Width="80" Height="30"
                        IsCancel="True"
                        Click="NoButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
