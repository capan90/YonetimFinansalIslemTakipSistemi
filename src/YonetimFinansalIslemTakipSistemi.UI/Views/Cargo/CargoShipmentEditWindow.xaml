<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Cargo.CargoShipmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        SizeToContent="Height" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="16">

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Tarih *:" Margin="0,0,0,2"/>
                <DatePicker SelectedDate="{Binding ShipmentDate, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Kargo No:" Margin="0,0,0,2"
                       ToolTip="Boş bırakılırsa otomatik üretilir (örn. G-2026-0001)"/>
                <TextBox Text="{Binding ShipmentNumber, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Boş bırakılırsa otomatik üretilir"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Kargo Türü:" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding ShipmentTypeOptions}"
                          SelectedItem="{Binding SelectedShipmentType, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Öncelik:" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding PriorityOptions}"
                          SelectedItem="{Binding SelectedPriority, Mode=TwoWay}"
                          ToolTip="Normal=gri, Orta=mavi, Acil=turuncu, Çok Acil=kırmızı"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <!-- AllowedStatusOptions: düzenleme modunda sadece geçerli geçişler listelenir -->
                <Label Content="Durum:" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding AllowedStatusOptions}"
                          SelectedItem="{Binding SelectedStatus, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Bildirim Durumu:" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding NotificationStatusOptions}"
                          SelectedItem="{Binding SelectedNotificationStatus, Mode=TwoWay}"
                          ToolTip="Gerçek WhatsApp/mail gönderimi yapılmaz; sadece durum kaydedilir."/>
            </StackPanel>
        </Grid>

        <!-- Kargo Firması + hızlı ekleme -->
        <Label Content="Kargo Firması:" Margin="0,0,0,2"/>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding CargoCompanies}"
                      SelectedItem="{Binding SelectedCargoCompany, Mode=TwoWay}"
                      DisplayMemberPath="Name"/>
            <Button x:Name="AddCargoCompanyButton" Grid.Column="2"
                    Content="+" Width="26" Height="22"
                    VerticalAlignment="Center"
                    ToolTip="Yeni kargo firması ekle"
                    Click="AddCargoCompanyButton_Click"/>
        </Grid>

        <!-- Firma Rehberi + hızlı ekleme -->
        <Label Content="Firma Rehberi (Karşı Taraf):" Margin="0,0,0,2"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding CompanyDirectories}"
                      SelectedItem="{Binding SelectedCompanyDirectory, Mode=TwoWay}"
                      DisplayMemberPath="CompanyName"
                      ToolTip="Giden kargoda firma seçilince alıcı adı otomatik dolar."/>
            <Button x:Name="AddDirectoryButton" Grid.Column="2"
                    Content="+" Width="26" Height="22"
                    VerticalAlignment="Center"
                    ToolTip="Yeni firma rehberi kaydı ekle"
                    Click="AddDirectoryButton_Click"/>
        </Grid>

        <!-- Firma seçildiğinde adres/iletişim özeti: salt okunur bilgi paneli -->
        <Border Margin="0,0,0,8" Padding="8" Background="#F0F4FF" BorderBrush="#B0C4F0" BorderThickness="1" CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasDirectoryDetails}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding DirectoryDetailSummary}"
                       TextWrapping="Wrap" FontSize="11"
                       Foreground="#334477"/>
        </Border>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Gönderen:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding SenderName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Alıcı:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding ReceiverName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Teslim Eden:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding DeliveredBy, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Teslim Alan:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding ReceivedBy, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Takip No:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding TrackingNumber, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Araç Plakası:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding VehiclePlate, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <Label Content="Takip Linki:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding TrackingUrl, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"
                 Foreground="#1565C0"
                 Background="#F0F8FF"
                 ToolTip="Boş ise Kargo Firması şablonu + Takip No ile otomatik üretilir. Manuel giriş otomatik üretimi devre dışı bırakır."/>

        <Label Content="Notlar:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                 Height="48" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,12"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Kaydet" Command="{Binding SaveCommand}" IsDefault="True" Width="80" Margin="0,0,8,0"/>
            <Button Content="İptal"  IsCancel="True" Width="80" Click="CancelButton_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
