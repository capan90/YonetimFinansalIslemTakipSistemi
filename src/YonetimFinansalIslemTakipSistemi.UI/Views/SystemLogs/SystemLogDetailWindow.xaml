<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.SystemLogs.SystemLogDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Detayı"
        Height="640" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Loaded="Window_Loaded">

    <DockPanel Margin="16">

        <!-- Butonlar — alt panel -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="0,10,0,0" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyStackTraceButton" Content="StackTrace Kopyala"
                        Click="CopyStackTrace_Click"
                        Margin="0,0,8,0" Padding="14,6"/>
                <Button x:Name="ResolveButton" Content="Çözüldü İşaretle"
                        Click="MarkResolved_Click"
                        Margin="0,0,8,0" Padding="14,6"/>
                <Button Content="Kapat" IsCancel="True" Padding="14,6"/>
            </StackPanel>
        </Border>

        <!-- İçerik -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel">

                <!-- Genel bilgiler grid -->
                <Border Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tarih:"        FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="CreatedAtText" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Seviye:"       FontWeight="SemiBold" Margin="8,0,0,6"/>
                        <TextBlock x:Name="LevelText"     Grid.Row="0" Grid.Column="3" FontWeight="Bold" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Kategori:"     FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="CategoryText"  Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Kaynak:"       FontWeight="SemiBold" Margin="8,0,0,6"/>
                        <TextBlock x:Name="SourceText"    Grid.Row="1" Grid.Column="3" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Kullanıcı:"   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="UsernameText"  Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Makine:"       FontWeight="SemiBold" Margin="8,0,0,6"/>
                        <TextBlock x:Name="MachineText"   Grid.Row="2" Grid.Column="3" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Sürüm:"        FontWeight="SemiBold" Margin="0,0,0,0"/>
                        <TextBlock x:Name="VersionText"   Grid.Row="3" Grid.Column="1" Margin="0,0,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Durum:"        FontWeight="SemiBold" Margin="8,0,0,0"/>
                        <TextBlock x:Name="StatusText"    Grid.Row="3" Grid.Column="3" FontWeight="SemiBold" Margin="0,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Mesaj -->
                <TextBlock Text="Mesaj" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1"
                        CornerRadius="4" Padding="10" Margin="0,0,0,10">
                    <TextBlock x:Name="MessageText" TextWrapping="Wrap"/>
                </Border>

                <!-- Exception tipi -->
                <TextBlock x:Name="ExceptionTypeLabel" Text="Exception Tipi" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox   x:Name="ExceptionTypeText"  IsReadOnly="True" Margin="0,0,0,10"
                           Background="#F8FAFC" BorderBrush="#E2E8F0" Padding="6"/>

                <!-- InnerException -->
                <TextBlock x:Name="InnerExLabel" Text="Inner Exception" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox   x:Name="InnerExText"  IsReadOnly="True" Margin="0,0,0,10"
                           Background="#F8FAFC" BorderBrush="#E2E8F0" Padding="6"
                           TextWrapping="Wrap" MaxHeight="80"/>

                <!-- StackTrace -->
                <TextBlock Text="Stack Trace" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox   x:Name="StackTraceText" IsReadOnly="True" Margin="0,0,0,10"
                           Background="#F8FAFC" BorderBrush="#E2E8F0" Padding="6"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Auto"
                           TextWrapping="NoWrap"
                           Height="140"
                           FontFamily="Consolas" FontSize="11"/>

                <!-- Çözüm notu -->
                <TextBlock x:Name="ResolutionSection" Text="Çözüm Notu" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox   x:Name="ResolutionNoteBox"
                           Margin="0,0,0,4" Padding="6" Height="60"
                           TextWrapping="Wrap"
                           AcceptsReturn="True"
                           VerticalScrollBarVisibility="Auto"
                           BorderBrush="#E2E8F0"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
