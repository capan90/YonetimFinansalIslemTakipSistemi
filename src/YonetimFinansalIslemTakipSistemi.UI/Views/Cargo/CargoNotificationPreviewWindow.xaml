<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Cargo.CargoNotificationPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhatsApp Mesajı Hazırla" Width="540" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">

    <DockPanel Margin="14">

        <!-- Başlık -->
        <TextBlock DockPanel.Dock="Top"
                   Text="WhatsApp Mesajı Hazırla"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <!-- Kargo bilgi alanı -->
        <Border DockPanel.Dock="Top"
                Background="#F0FFF0" BorderBrush="#A8D8A8" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="75"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="75"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Kargo No:" FontWeight="SemiBold" Margin="0,0,6,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           x:Name="ShipmentNumberBlock" Margin="0,0,12,4"/>

                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="Alıcı Firma:" FontWeight="SemiBold" Margin="0,0,6,4"/>
                <TextBlock Grid.Row="0" Grid.Column="3"
                           x:Name="ReceiverBlock" Margin="0,0,0,4"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Telefon:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           x:Name="PhoneBlock" Grid.ColumnSpan="3"/>
            </Grid>
        </Border>

        <!-- Alt butonlar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CopyButton"
                    Content="Kopyala" Width="90" Margin="0,0,8,0"
                    Click="CopyButton_Click"
                    ToolTip="Mesajı panoya kopyalar"/>
            <Button x:Name="WhatsAppWebButton"
                    Content="WhatsApp Web'de Aç" Width="150" Margin="0,0,8,0"
                    Click="WhatsAppWebButton_Click"
                    ToolTip="Telefon numarasıyla WhatsApp Web sayfasını açar"/>
            <Button x:Name="MarkPreparedButton"
                    Content="Hazırlandı Olarak İşaretle" Width="190" Margin="0,0,8,0"
                    Click="MarkPreparedButton_Click"
                    ToolTip="Bildirim durumunu 'WhatsApp Hazır' yapar ve audit kaydı oluşturur"/>
            <Button Content="Kapat" Width="75"
                    IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>

        <!-- Mesaj metni -->
        <TextBox x:Name="MessageBodyBox"
                 IsReadOnly="True" AcceptsReturn="True"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontFamily="Segoe UI" FontSize="13"
                 Background="#FAFAFA" BorderBrush="#CBD5E1" BorderThickness="1"
                 Padding="10"/>

    </DockPanel>
</Window>
