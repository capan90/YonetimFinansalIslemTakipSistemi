<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:YonetimFinansalIslemTakipSistemi.UI.Converters">

    <!-- ── Converter ─────────────────────────────────────────────────────────── -->
    <converters:DecimalToColorConverter         x:Key="BalanceToColor"/>
    <converters:SystemLogLevelToColorConverter  x:Key="LevelToBackgroundConverter"/>
    <converters:SystemLogLevelToColorConverter  x:Key="LevelToForegroundConverter" />
    <converters:BoolToStatusColorConverter      x:Key="BoolToStatusColorConverter"/>

    <!-- ── Sabit Renk Fırçaları (StaticResource ile referans verilen mevcut isimler) ── -->
    <!-- Not: Tema fırçaları (Theme.*) ayrı LightTheme/DarkTheme.xaml dosyalarındadır -->
    <SolidColorBrush x:Key="Brush.Primary"       Color="#1E3A5F"/>
    <SolidColorBrush x:Key="Brush.Success"       Color="#2E7D32"/>
    <SolidColorBrush x:Key="Brush.Danger"        Color="#C62828"/>
    <SolidColorBrush x:Key="Brush.Secondary"     Color="#475569"/>
    <SolidColorBrush x:Key="Brush.Disabled"      Color="#94A3B8"/>
    <SolidColorBrush x:Key="Brush.Border"        Color="#E2E8F0"/>
    <SolidColorBrush x:Key="Brush.GridAlt"       Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Brush.GridSelected"  Color="#DBEAFE"/>
    <SolidColorBrush x:Key="Brush.GridHover"     Color="#EFF6FF"/>
    <SolidColorBrush x:Key="Brush.TextPrimary"   Color="#1A202C"/>
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#64748B"/>

    <!-- ── Buton Stilleri ────────────────────────────────────────────────────── -->

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background"      Value="{DynamicResource Theme.Primary}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.PrimaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#152C4A"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="#94A3B8"/>
                            <Setter TargetName="Bd" Property="Opacity"    Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background"      Value="#475569"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="#94A3B8"/>
                            <Setter TargetName="Bd" Property="Opacity"    Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Background"      Value="#C62828"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#B71C1C"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#7F1010"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="#94A3B8"/>
                            <Setter TargetName="Bd" Property="Opacity"    Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TextBox ──────────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Padding"                  Value="6,4"/>
        <Setter Property="BorderBrush"              Value="{DynamicResource Theme.InputBorder}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Background"               Value="{DynamicResource Theme.InputBackground}"/>
        <Setter Property="Foreground"               Value="{DynamicResource Theme.Text}"/>
        <Setter Property="CaretBrush"               Value="{DynamicResource Theme.Text}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Theme.InputBorderFocus}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── PasswordBox ──────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Padding"                  Value="6,4"/>
        <Setter Property="BorderBrush"              Value="{DynamicResource Theme.InputBorder}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Background"               Value="{DynamicResource Theme.InputBackground}"/>
        <Setter Property="Foreground"               Value="{DynamicResource Theme.Text}"/>
        <Setter Property="CaretBrush"               Value="{DynamicResource Theme.Text}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ── ComboBox ─────────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{DynamicResource Theme.InputBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.InputBorder}"/>
    </Style>

    <!-- ── DataGrid ──────────────────────────────────────────────────────────── -->
    <!-- SelectionUnit="FullRow": tıklamada tüm satır hücreleri seçilir.
         Seçim rengi DataGridCell trigger üzerinden uygulanır — AlternatingRowBackground
         satıra local value koyduğu için DataGridRow trigger etkisiz kalır;
         DataGridCell trigger local value taşımaz, dolayısıyla güvenilir çalışır. -->
    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="HeadersVisibility"    Value="Column"/>
        <Setter Property="SelectionUnit"        Value="FullRow"/>
        <Setter Property="Background"           Value="{DynamicResource Theme.DataGridRow}"/>
        <Setter Property="RowBackground"        Value="{DynamicResource Theme.DataGridRow}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource Theme.DataGridAltRow}"/>
        <Setter Property="Foreground"           Value="{DynamicResource Theme.Text}"/>
        <Setter Property="BorderBrush"          Value="{DynamicResource Theme.Border}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Theme.Border}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="{DynamicResource Theme.Border}"/>
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background"                 Value="{DynamicResource Theme.DataGridHeader}"/>
        <Setter Property="Foreground"                 Value="{DynamicResource Theme.DataGridHeaderText}"/>
        <Setter Property="FontWeight"                 Value="SemiBold"/>
        <Setter Property="FontSize"                   Value="12"/>
        <Setter Property="Padding"                    Value="8,6"/>
        <Setter Property="BorderBrush"                Value="{DynamicResource Theme.Border}"/>
        <Setter Property="BorderThickness"            Value="0,0,1,1"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor"                     Value="Arrow"/>
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{DynamicResource Theme.Text}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Theme.DataGridSelectedRow}"/>
                <Setter Property="Foreground" Value="{DynamicResource Theme.DataGridSelectedText}"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True"/>
                    <Condition Property="IsSelected"  Value="False"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter Property="Background" Value="{DynamicResource Theme.DataGridHoverRow}"/>
                </MultiTrigger.Setters>
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Foreground"       Value="{DynamicResource Theme.Text}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background"  Value="{DynamicResource Theme.DataGridSelectedRow}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Foreground"  Value="{DynamicResource Theme.DataGridSelectedText}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
