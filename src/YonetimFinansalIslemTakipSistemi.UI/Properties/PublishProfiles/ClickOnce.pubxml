<?xml version="1.0" encoding="utf-8"?>
<!--
  ClickOnce publish profili
  Sunucu değişince: PublishUrl (lokal hedef), InstallUrl, UpdateUrl ve
  DeploymentSettings.cs güncellenir — kod değişmez.

  Publish komutu:
    dotnet publish src\YonetimFinansalIslemTakipSistemi.UI -p:PublishProfile=ClickOnce
  Publish öncesi zorunlu: dotnet ef database update (yönetici)
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>

    <PublishProtocol>ClickOnce</PublishProtocol>
    <InstallFrom>Unc</InstallFrom>

    <!-- Fiziksel çıktı hedefi (Windows paylaşımının lokal yolu) -->
    <PublishUrl>C:\Apps\Yonetim\Publish\</PublishUrl>
    <!-- Kurulum ve güncelleme kaynağı: UNC erişimi -->
    <InstallUrl>\\localhost\YonetimPublish\</InstallUrl>
    <UpdateUrl>\\localhost\YonetimPublish\</UpdateUrl>

    <!-- Foreground: uygulama açılmadan önce ClickOnce manifest kontrolü yapar -->
    <UpdateEnabled>true</UpdateEnabled>
    <UpdateMode>Foreground</UpdateMode>
    <!-- false: kullanıcı güncellemeyi erteleyebilir -->
    <UpdateRequired>false</UpdateRequired>

    <!--
      Her release öncesi artırılır: 1.0.0.0 → 1.0.0.1 → ...
      csproj AssemblyVersion ve AfterTargets WriteVersionJson ile senkron.
    -->
    <PublishVersion>1.0.0.0</PublishVersion>
    <ApplicationVersion>1.0.0.*</ApplicationVersion>
    <ApplicationRevision>0</ApplicationRevision>

    <!--
      Sertifika: self-signed, Cert:\CurrentUser\My'da.
      Thumbprint: 0136460438B6DED7F20498C00F7D3AB4C1E1B203
      PFX veya private key repoya eklenmez.
    -->
    <SignManifests>true</SignManifests>
    <ManifestCertificateThumbprint>0136460438B6DED7F20498C00F7D3AB4C1E1B203</ManifestCertificateThumbprint>

    <!-- .NET runtime bootstrapper dahil edilmez; runtime önceden kurulu kabul edilir -->
    <BootstrapperEnabled>false</BootstrapperEnabled>
    <MapFileExtensions>true</MapFileExtensions>

    <CreateDesktopShortcut>true</CreateDesktopShortcut>
    <CreateWebPageOnPublish>false</CreateWebPageOnPublish>

    <ProductName>Yönetim Finansal İşlem Takip Sistemi</ProductName>
    <PublisherName>Test Publisher</PublisherName>

    <!--
      dotnet publish, VS'in PublishOnly zincirini çalıştırmaz; SetGenerateManifests target'ı atlanır.
      Microsoft.Common.CurrentVersion.targets(275) GenerateClickOnceManifests = $(GenerateManifests) yapar;
      o anda GenerateManifests boşsa GenerateClickOnceManifests de boş kalır ve launcher oluşmaz.
      Pubxml çok erken import edildiğinden her iki flag'ı burada önceden true yapıyoruz.
    -->
    <GenerateManifests>true</GenerateManifests>
    <GenerateClickOnceManifests>true</GenerateClickOnceManifests>
  </PropertyGroup>
</Project>
