<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Reports.ReportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rapor Önizleme"
        Height="720" Width="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <DockPanel Margin="16">

        <!-- Buton çubuğu -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#DDD"
                Padding="0,10,0,0"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="PDF Kaydet"   Width="110" Margin="0,0,8,0"
                        ToolTip="Raporu PDF formatında dışa aktarır ve kaydetmenizi sağlar."
                        Click="SavePdf_Click"/>
                <Button Content="Excel Kaydet" Width="110" Margin="0,0,8,0"
                        ToolTip="Raporu Excel (.xlsx) formatında dışa aktarır."
                        Click="SaveExcel_Click"/>
                <Button Content="Kapat"        Width="80"
                        Click="Close_Click"/>
            </StackPanel>
        </Border>

        <!-- Rapor içeriği -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Başlık -->
                <TextBlock Text="Finansal Rapor"
                           FontSize="18" FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="DateRangeText"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="FilterSummaryText"
                           FontSize="11" Foreground="#888" FontStyle="Italic"
                           Margin="0,0,0,12"/>
                <Separator Margin="0,0,0,12"/>

                <!-- Para Birimi Özet Kartları -->
                <TextBlock Text="Para Birimi Özeti"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <UniformGrid x:Name="SummaryGrid" Columns="3" Margin="0,0,0,16"/>

                <!-- İşlem Türü Tablosu -->
                <TextBlock Text="İşlem Türü Bazında Toplam"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <DataGrid x:Name="TypeDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F5F5F5"
                          HeadersVisibility="Column"
                          Margin="0,0,0,16">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="İşlem Türü" Binding="{Binding TypeDisplay}" Width="90"/>
                        <DataGridTextColumn Header="TL Borç"    Binding="{Binding TryBorc,  StringFormat=N2}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TL Alacak"  Binding="{Binding TryAlacak, StringFormat=N2}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TL Adet"    Binding="{Binding TryCount}" Width="55">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="USD Borç"   Binding="{Binding UsdBorc,  StringFormat=N2}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="USD Alacak" Binding="{Binding UsdAlacak, StringFormat=N2}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="USD Adet"   Binding="{Binding UsdCount}" Width="55">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EUR Borç"   Binding="{Binding EurBorc,  StringFormat=N2}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EUR Alacak" Binding="{Binding EurAlacak, StringFormat=N2}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EUR Adet"   Binding="{Binding EurCount}" Width="55">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- İşlem Detay Tablosu — yalnızca detay istendiğinde görünür -->
                <StackPanel x:Name="DetailSection" Visibility="Collapsed">
                    <TextBlock Text="İşlem Detayları"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <DataGrid x:Name="DetailDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F5F5F5"
                              HeadersVisibility="Column"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih"     Binding="{Binding Date}"            Width="80"/>
                            <DataGridTextColumn Header="Açıklama"  Binding="{Binding Description}"     Width="*"/>
                            <DataGridTextColumn Header="Tür"       Binding="{Binding TypeDisplay}"     Width="65"/>
                            <DataGridTextColumn Header="Para Bir." Binding="{Binding CurrencyDisplay}" Width="65"/>
                            <DataGridTextColumn Header="Borç"      Binding="{Binding Borc,    StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Alacak"    Binding="{Binding Alacak,  StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Bakiye"    Binding="{Binding Balance,  StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- Genel Toplamlar (her zaman gösterilir) -->
                <Border x:Name="TotalsPanel"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#DDD"
                        Padding="0,8,0,0"
                        Margin="0,4,0,0"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
