<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Yönetim — Nakit İşlemler" Height="600" Width="1280">

    <DockPanel>

        <!-- Menü çubuğu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Yönetim">
                <!-- Visibility: UI gizlemesi; asıl koruma handler seviyesindedir -->
                <MenuItem x:Name="MenuItemKullanicilar"
                          Header="Kullanıcılar"
                          Click="OpenUserManagement_Click"/>
                <MenuItem x:Name="MenuItemYetkiler"
                          Header="Yetkiler"
                          Click="OpenPermissions_Click"/>
                <MenuItem x:Name="MenuItemDenetim"
                          Header="Denetim Günlüğü"
                          Click="OpenAuditLog_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuItemRaporlar"
                          Header="Raporlar"
                          Click="OpenReports_Click"/>
                <MenuItem x:Name="MenuItemAnaliz"
                          Header="Finans Analiz Merkezi"
                          Click="OpenAnalysis_Click"/>
                <MenuItem x:Name="MenuItemDoviz"
                          Header="Döviz Kurları"
                          Click="OpenExchangeRates_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuItemDbTest"
                          Header="Veritabanı Bağlantısını Test Et"
                          ToolTip="Mevcut veritabanı bağlantısını hemen test eder ve sonucu gösterir."
                          Click="TestDbConnection_Click"/>
                <MenuItem x:Name="MenuItemLogKlasor"
                          Header="Log Klasörünü Aç"
                          ToolTip="Uygulama log dosyalarının bulunduğu klasörü Explorer'da açar."
                          Click="OpenLogDirectory_Click"/>
                <MenuItem x:Name="MenuItemSistemSagligi"
                          Header="Sistem Sağlığı"
                          ToolTip="Uygulama, veritabanı, log, backup ve güncelleme durumunu özetler."
                          Click="OpenSystemHealth_Click"/>
            </MenuItem>
            <!-- Kargo Katip modülü -->
            <MenuItem x:Name="MenuItemKargoKatip" Header="Kargo Katip">
                <MenuItem x:Name="MenuItemKargoDashboard"
                          Header="Dashboard"
                          Click="OpenCargoDashboard_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuItemGelenKargolar"
                          Header="Gelen Kargolar"
                          Click="OpenIncomingCargo_Click"/>
                <MenuItem x:Name="MenuItemGidenKargolar"
                          Header="Giden Kargolar"
                          Click="OpenOutgoingCargo_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuItemFirmaRehberi"
                          Header="Firma Rehberi"
                          Click="OpenCompanyDirectory_Click"/>
                <MenuItem x:Name="MenuItemKargoFirmalari"
                          Header="Kargo Firmaları"
                          Click="OpenCargoCompanies_Click"/>
            </MenuItem>
            <MenuItem Header="Yardım">
                <MenuItem Header="Güncellemeleri Denetle"
                          ToolTip="Yayın klasöründeki en güncel sürümü kontrol eder; güncelleme varsa bildirir."
                          Click="CheckForUpdates_Click"/>
            </MenuItem>
        </Menu>

    <DockPanel Margin="8">

        <!-- Bakiye Özeti — filtreden bağımsız, tüm zamanların kümülatif bakiyesi -->
        <Border DockPanel.Dock="Top"
                Background="#F0F4F8"
                BorderBrush="#C8D6E5"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,6"
                Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="TL:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding TlBalance, StringFormat=N2}" FontWeight="Bold"
                           Foreground="#1A5276" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="USD:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding UsdBalance, StringFormat=N2}" FontWeight="Bold"
                           Foreground="#1A5276" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="EUR:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding EurBalance, StringFormat=N2}" FontWeight="Bold"
                           Foreground="#1A5276" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Araç çubuğu -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <!-- Sağ: kullanıcı adı + çıkış butonu — DockPanel'de önce Dock="Right" olan yerleşir -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="LoggedInUserText"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="#555555"/>
                <Button Content="Çıkış Yap" Width="90"
                        Click="Logout_Click"/>
            </StackPanel>
            <!-- Sol: işlem butonları -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="+ Yeni İşlem" Width="110" Margin="0,0,6,0"
                        ToolTip="Yeni bir nakit işlem kaydı oluşturur."
                        Click="NewTransactionButton_Click"/>
                <Button Content="Düzenle" Width="80" Margin="0,0,6,0"
                        ToolTip="Seçili işlemi düzenler."
                        IsEnabled="{Binding HasSelectedTransaction}"
                        Click="EditTransactionButton_Click"/>
                <Button Content="Sil" Width="60"
                        ToolTip="Seçili işlemi kalıcı olarak siler."
                        IsEnabled="{Binding HasSelectedTransaction}"
                        Click="DeleteTransactionButton_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Filtre Paneli -->
        <GroupBox DockPanel.Dock="Top" Header="Filtrele" Margin="0,0,0,8" Padding="8">
            <WrapPanel Orientation="Horizontal" ItemHeight="30">

                <Label Content="Başlangıç:" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                            Width="130" Margin="0,0,12,0"/>

                <Label Content="Bitiş:" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                            Width="130" Margin="0,0,12,0"/>

                <Label Content="İşlem Türü:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding TransactionTypeOptions}"
                          SelectedItem="{Binding SelectedTransactionType, Mode=TwoWay}"
                          Width="90" Margin="0,0,12,0"/>

                <Label Content="Para Birimi:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding CurrencyTypeOptions}"
                          SelectedItem="{Binding SelectedCurrencyType, Mode=TwoWay}"
                          Width="90" Margin="0,0,12,0"/>

                <Label Content="Açıklama:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding DescriptionFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="160" Margin="0,0,12,0" VerticalContentAlignment="Center"/>

                <Label Content="Tutar:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding AmountOperatorOptions}"
                          SelectedItem="{Binding SelectedAmountOperator, Mode=TwoWay}"
                          Width="48" Margin="0,0,4,0"/>
                <TextBox Text="{Binding AmountValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="90" Margin="0,0,12,0" VerticalContentAlignment="Center"/>

                <Button Content="Filtrele"
                        Command="{Binding FilterCommand}"
                        Width="80" Padding="4,0"/>

            </WrapPanel>
        </GroupBox>

        <!-- İşlem Listesi
             Kolon sırası: Tarih | Tür | Para Bir. | Açıklama | Borç | Alacak | Bakiye(ler) | Oluşturulma
             Bakiye kolonları para birimi filtresine göre kod arkasında gizlenir/gösterilir.
             Kolon başlığına sağ tıklayarak gizleme ve tasarım kaydetme mevcuttur.
        -->
        <DataGrid x:Name="TransactionDataGrid"
                  ItemsSource="{Binding Transactions}"
                  SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F5F5"
                  HeadersVisibility="Column">

            <!-- Sağ tıklama context menu'su kod arkasında atanır (bkz. MainWindow.xaml.cs) -->

            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColTarih"
                                    Header="Tarih"
                                    Binding="{Binding TransactionDate, StringFormat=dd.MM.yyyy}"
                                    Width="90"/>
                <DataGridTextColumn x:Name="ColTur"
                                    Header="Tür"
                                    Binding="{Binding TransactionTypeDisplay}"
                                    Width="80"/>
                <DataGridTextColumn x:Name="ColParaBir"
                                    Header="Para Bir."
                                    Binding="{Binding CurrencyTypeDisplay}"
                                    Width="75"/>
                <DataGridTextColumn x:Name="ColAciklama"
                                    Header="Açıklama"
                                    Binding="{Binding Description}"
                                    Width="*"/>
                <DataGridTextColumn x:Name="ColBorc"
                                    Header="Borç"
                                    Binding="{Binding Borc, StringFormat=N2}"
                                    Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="ColAlacak"
                                    Header="Alacak"
                                    Binding="{Binding Alacak, StringFormat=N2}"
                                    Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="ColTlBakiye"
                                    Header="TL Bakiye"
                                    Binding="{Binding TlBalanceAfter, StringFormat=N2}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="ColUsdBakiye"
                                    Header="USD Bakiye"
                                    Binding="{Binding UsdBalanceAfter, StringFormat=N2}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="ColEurBakiye"
                                    Header="EUR Bakiye"
                                    Binding="{Binding EurBalanceAfter, StringFormat=N2}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="ColOlusturulmaT"
                                    Header="Oluşturulma"
                                    Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>

    </DockPanel>
</Window>
