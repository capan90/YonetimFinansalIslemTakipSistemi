<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.CashTransactions.CashTransactionFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        SizeToContent="Height"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">

        <Label Content="İşlem Tarihi:" Margin="0,0,0,2"/>
        <DatePicker SelectedDate="{Binding TransactionDate, Mode=TwoWay}"
                    Margin="0,0,0,10"/>

        <Label Content="İşlem Türü:" Margin="0,0,0,2"/>
        <ComboBox ItemsSource="{Binding TransactionTypeOptions}"
                  SelectedItem="{Binding SelectedTransactionType, Mode=TwoWay}"
                  Margin="0,0,0,10"/>

        <Label Content="Para Birimi:" Margin="0,0,0,2"/>
        <ComboBox ItemsSource="{Binding CurrencyTypeOptions}"
                  SelectedItem="{Binding SelectedCurrencyType, Mode=TwoWay}"
                  Margin="0,0,0,10"/>

        <Label Content="Tutar:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"/>

        <Label Content="Açıklama:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,14"/>

        <!-- Hata mesajı -->
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Kaydet"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Width="80" Margin="0,0,8,0"/>
            <Button Content="İptal"
                    IsCancel="True"
                    Width="80"
                    Click="CancelButton_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
