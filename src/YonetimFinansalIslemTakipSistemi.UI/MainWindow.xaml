<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Yönetim — Nakit İşlemler"
        Height="640" Width="1280"
        MinWidth="900" MinHeight="500"
        Icon="Assets/AppIcon.ico">

    <DockPanel Background="#F5F7FA">

        <!-- Menü çubuğu -->
        <Menu DockPanel.Dock="Top" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <MenuItem Header="Yönetim">
                <!-- Sadece iş/yönetim işlevleri; teknik işlemler Ayarlar altına taşındı -->
                <MenuItem x:Name="MenuItemKullanicilar"
                          Header="Kullanıcılar"
                          Click="OpenUserManagement_Click"/>
                <MenuItem x:Name="MenuItemYetkiler"
                          Header="Yetkiler"
                          Click="OpenPermissions_Click"/>
                <MenuItem x:Name="MenuItemDenetim"
                          Header="Denetim Günlüğü"
                          Click="OpenAuditLog_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuItemRaporlar"
                          Header="Raporlar"
                          Click="OpenReports_Click"/>
                <MenuItem x:Name="MenuItemAnaliz"
                          Header="Finans Analiz Merkezi"
                          Click="OpenAnalysis_Click"/>
                <MenuItem x:Name="MenuItemDoviz"
                          Header="Döviz Kurları"
                          Click="OpenExchangeRates_Click"/>
            </MenuItem>

            <!-- Kargo Takip modülü -->
            <MenuItem x:Name="MenuItemKargoKatip" Header="Kargo Takip">
                <MenuItem x:Name="MenuItemKargoDashboard"
                          Header="Dashboard"
                          Click="OpenCargoDashboard_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuItemGelenKargolar"
                          Header="Gelen Kargolar"
                          Click="OpenIncomingCargo_Click"/>
                <MenuItem x:Name="MenuItemGidenKargolar"
                          Header="Giden Kargolar"
                          Click="OpenOutgoingCargo_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuItemFirmaRehberi"
                          Header="Firma Rehberi"
                          Click="OpenCompanyDirectory_Click"/>
                <MenuItem x:Name="MenuItemKargoFirmalari"
                          Header="Kargo Firmaları"
                          Click="OpenCargoCompanies_Click"/>
            </MenuItem>

            <!-- Ayarlar: mail + teknik/operasyonel işlemler -->
            <MenuItem x:Name="MenuItemAyarlar" Header="Ayarlar">
                <MenuItem x:Name="MenuItemMailAyarlari"
                          Header="Mail Ayarları"
                          ToolTip="SMTP sunucusu ve e-posta bildirim ayarlarını yönetin."
                          Click="OpenMailSettings_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuItemSistemSagligi"
                          Header="Sistem Sağlığı"
                          ToolTip="Uygulama, veritabanı, log, backup ve güncelleme durumunu özetler."
                          Click="OpenSystemHealth_Click"/>
                <MenuItem x:Name="MenuItemDbTest"
                          Header="Veritabanı Bağlantısını Test Et"
                          ToolTip="Mevcut veritabanı bağlantısını hemen test eder ve sonucu gösterir."
                          Click="TestDbConnection_Click"/>
                <MenuItem x:Name="MenuItemLogKlasor"
                          Header="Log Klasörünü Aç"
                          ToolTip="Uygulama log dosyalarının bulunduğu klasörü Explorer'da açar."
                          Click="OpenLogDirectory_Click"/>
            </MenuItem>

            <MenuItem Header="Yardım">
                <MenuItem Header="Güncellemeleri Denetle"
                          ToolTip="Yayın klasöründeki en güncel sürümü kontrol eder; güncelleme varsa bildirir."
                          Click="CheckForUpdates_Click"/>
            </MenuItem>
        </Menu>

        <DockPanel Margin="10">

            <!-- Bakiye Kartları — para birimi başına ayrı kart, renk bağlaması converter ile -->
            <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="0,0,0,10">

                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,6,0" Padding="14,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#CBD5E1" Direction="270" ShadowDepth="1"
                                          BlurRadius="6" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="TL BAKİYE"
                                   Foreground="#64748B" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding TlBalance, StringFormat=N2}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{Binding TlBalance, Converter={StaticResource BalanceToColor}}"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="6" Margin="3,0,3,0" Padding="14,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#CBD5E1" Direction="270" ShadowDepth="1"
                                          BlurRadius="6" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="USD BAKİYE"
                                   Foreground="#64748B" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding UsdBalance, StringFormat=N2}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{Binding UsdBalance, Converter={StaticResource BalanceToColor}}"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="6" Margin="6,0,0,0" Padding="14,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#CBD5E1" Direction="270" ShadowDepth="1"
                                          BlurRadius="6" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="EUR BAKİYE"
                                   Foreground="#64748B" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding EurBalance, StringFormat=N2}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{Binding EurBalance, Converter={StaticResource BalanceToColor}}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Araç çubuğu -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <!-- Sağ: kullanıcı + çıkış -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LoggedInUserText"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Foreground="#475569"
                               FontSize="13"/>
                    <Button Content="Çıkış Yap"
                            Width="90"
                            Style="{StaticResource SecondaryButton}"
                            Click="Logout_Click"/>
                </StackPanel>
                <!-- Sol: işlem butonları -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ Yeni İşlem"
                            Width="110" Margin="0,0,6,0"
                            Style="{StaticResource PrimaryButton}"
                            ToolTip="Yeni bir nakit işlem kaydı oluşturur."
                            Click="NewTransactionButton_Click"/>
                    <Button Content="Düzenle"
                            Width="80" Margin="0,0,6,0"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="Seçili işlemi düzenler."
                            IsEnabled="{Binding HasSelectedTransaction}"
                            Click="EditTransactionButton_Click"/>
                    <Button x:Name="CopyTransactionButton"
                            Content="Kopyala"
                            Width="80" Margin="0,0,6,0"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="Seçili işlemin bilgileriyle yeni işlem formu açar."
                            IsEnabled="{Binding HasSelectedTransaction}"
                            Click="CopyTransactionButton_Click"/>
                    <Button Content="Sil"
                            Width="60"
                            Style="{StaticResource DangerButton}"
                            ToolTip="Seçili işlemi kalıcı olarak siler."
                            IsEnabled="{Binding HasSelectedTransaction}"
                            Click="DeleteTransactionButton_Click"/>
                </StackPanel>
            </DockPanel>

            <!-- Filtre Paneli -->
            <Border DockPanel.Dock="Top"
                    Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                    CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                <WrapPanel Orientation="Horizontal" ItemHeight="30">

                    <Label Content="Başlangıç:" VerticalAlignment="Center" Foreground="#475569"/>
                    <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                Width="130" Margin="0,0,10,0"/>

                    <Label Content="Bitiş:" VerticalAlignment="Center" Foreground="#475569"/>
                    <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                Width="130" Margin="0,0,10,0"/>

                    <Label Content="İşlem Türü:" VerticalAlignment="Center" Foreground="#475569"/>
                    <ComboBox ItemsSource="{Binding TransactionTypeOptions}"
                              SelectedItem="{Binding SelectedTransactionType, Mode=TwoWay}"
                              Width="90" Margin="0,0,10,0"/>

                    <Label Content="Para Birimi:" VerticalAlignment="Center" Foreground="#475569"/>
                    <ComboBox ItemsSource="{Binding CurrencyTypeOptions}"
                              SelectedItem="{Binding SelectedCurrencyType, Mode=TwoWay}"
                              Width="90" Margin="0,0,10,0"/>

                    <Label Content="Açıklama:" VerticalAlignment="Center" Foreground="#475569"/>
                    <TextBox Text="{Binding DescriptionFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="160" Margin="0,0,10,0"/>

                    <Label Content="Tutar:" VerticalAlignment="Center" Foreground="#475569"/>
                    <ComboBox ItemsSource="{Binding AmountOperatorOptions}"
                              SelectedItem="{Binding SelectedAmountOperator, Mode=TwoWay}"
                              Width="48" Margin="0,0,4,0"/>
                    <TextBox Text="{Binding AmountValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="90" Margin="0,0,10,0"/>

                    <Button Content="Filtrele"
                            Command="{Binding FilterCommand}"
                            Width="80"
                            Style="{StaticResource PrimaryButton}"/>

                </WrapPanel>
            </Border>

            <!-- İşlem Listesi -->
            <DataGrid x:Name="TransactionDataGrid"
                      ItemsSource="{Binding Transactions}"
                      SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E2E8F0"
                      AlternatingRowBackground="#F8FAFC"
                      RowBackground="White"
                      HeadersVisibility="Column"
                      BorderBrush="#E2E8F0"
                      BorderThickness="1"
                      RowHeight="30">

                <!-- Sağ tıklama context menu'su kod arkasında atanır (bkz. MainWindow.xaml.cs) -->

                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColTarih"
                                        Header="Tarih"
                                        Binding="{Binding TransactionDate, StringFormat=dd.MM.yyyy}"
                                        Width="90"/>
                    <DataGridTextColumn x:Name="ColTur"
                                        Header="Tür"
                                        Binding="{Binding TransactionTypeDisplay}"
                                        Width="80"/>
                    <DataGridTextColumn x:Name="ColParaBir"
                                        Header="Para Bir."
                                        Binding="{Binding CurrencyTypeDisplay}"
                                        Width="75"/>
                    <DataGridTextColumn x:Name="ColAciklama"
                                        Header="Açıklama"
                                        Binding="{Binding Description}"
                                        Width="*"/>
                    <DataGridTextColumn x:Name="ColBorc"
                                        Header="Borç"
                                        Binding="{Binding Borc, StringFormat=N2}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="#2E7D32"/>
                                <Setter Property="Padding" Value="0,0,4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn x:Name="ColAlacak"
                                        Header="Alacak"
                                        Binding="{Binding Alacak, StringFormat=N2}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="#C62828"/>
                                <Setter Property="Padding" Value="0,0,4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn x:Name="ColTlBakiye"
                                        Header="TL Bakiye"
                                        Binding="{Binding TlBalanceAfter, StringFormat=N2}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn x:Name="ColUsdBakiye"
                                        Header="USD Bakiye"
                                        Binding="{Binding UsdBalanceAfter, StringFormat=N2}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn x:Name="ColEurBakiye"
                                        Header="EUR Bakiye"
                                        Binding="{Binding EurBalanceAfter, StringFormat=N2}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn x:Name="ColOlusturulmaT"
                                        Header="Oluşturulma"
                                        Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                        Width="130"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>

    </DockPanel>
</Window>
