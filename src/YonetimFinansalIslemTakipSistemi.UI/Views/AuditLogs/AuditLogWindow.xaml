<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.AuditLogs.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Denetim Günlüğü"
        Height="560" Width="1000"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Loaded="Window_Loaded">

    <DockPanel Margin="10">

        <!-- Filtre paneli -->
        <Border DockPanel.Dock="Top"
                BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="4" Padding="10,8"
                Margin="0,0,0,8">
            <WrapPanel Orientation="Horizontal">

                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="Kullanıcı:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="160"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding FilterUser, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="Başlangıç:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker Width="120"
                                SelectedDate="{Binding FilterDateFrom, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="Bitiş:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker Width="120"
                                SelectedDate="{Binding FilterDateTo, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="İşlem Tipi:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="180"
                              ItemsSource="{Binding Actions}"
                              SelectedItem="{Binding FilterAction, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Button Content="Filtrele" Width="80" Margin="0,0,6,4"
                        Command="{Binding FilterCommand}"/>
                <Button Content="Temizle" Width="80" Margin="0,0,0,4"
                        Command="{Binding ClearCommand}"/>

            </WrapPanel>
        </Border>

        <!-- Kayıt sayısı -->
        <TextBlock DockPanel.Dock="Bottom"
                   Margin="0,6,0,0"
                   Foreground="#666"
                   Text="{Binding Logs.Count, StringFormat='Toplam {0} kayıt'}"/>

        <!-- Audit log listesi -->
        <DataGrid ItemsSource="{Binding Logs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8F8F8"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Zaman"
                                    Binding="{Binding Timestamp, StringFormat=dd.MM.yyyy HH:mm:ss}"
                                    Width="140"/>
                <DataGridTextColumn Header="Kullanıcı"
                                    Binding="{Binding UserName}"
                                    Width="120"/>
                <DataGridTextColumn Header="İşlem"
                                    Binding="{Binding ActionDisplay}"
                                    Width="160"/>
                <DataGridTextColumn Header="Varlık"
                                    Binding="{Binding EntityType}"
                                    Width="110"/>
                <DataGridTextColumn Header="Bilgisayar"
                                    Binding="{Binding ComputerName}"
                                    Width="110"/>
                <DataGridTextColumn Header="Eski Değer"
                                    Binding="{Binding OldValues}"
                                    Width="*"/>
                <DataGridTextColumn Header="Yeni Değer"
                                    Binding="{Binding NewValues}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
