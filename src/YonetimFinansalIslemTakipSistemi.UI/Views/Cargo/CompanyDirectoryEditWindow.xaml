<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Cargo.CompanyDirectoryEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/AppIcon.ico">

    <StackPanel Margin="16">

        <Label Content="Firma Adı *:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Content="İlgili Kişi:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Content="Dikkatine:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding AttentionTo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Content="Adres *:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding AddressLine, UpdateSourceTrigger=PropertyChanged}"
                 Height="56" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="İlçe:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding District, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Şehir:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Posta Kodu:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Telefon:" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="20"
                         PreviewTextInput="PhoneTextBox_PreviewTextInput"
                         ToolTip="Rakam, boşluk ve +, -, (, ) karakterleri; en fazla 20 karakter"/>
            </StackPanel>
        </Grid>

        <Label Content="E-posta:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Content="Notlar:" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                 Height="48" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,8"/>

        <CheckBox Content="Aktif" IsChecked="{Binding IsActive}" Margin="0,0,0,12"/>

        <!-- Hata mesajı -->
        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Kaydet" Command="{Binding SaveCommand}" IsDefault="True"
                    Width="80" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButton}"/>
            <Button Content="İptal"  IsCancel="True" Width="80"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
