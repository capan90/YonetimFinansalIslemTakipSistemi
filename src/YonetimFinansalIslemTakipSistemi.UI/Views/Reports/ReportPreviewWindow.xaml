<Window x:Class="YonetimFinansalIslemTakipSistemi.UI.Views.Reports.ReportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rapor Önizleme"
        Height="640" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <DockPanel Margin="16">

        <!-- Buton çubuğu — DockPanel'de önce Dock="Bottom" olan yerleşir -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#DDD"
                Padding="0,10,0,0"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="PDF Kaydet"   Width="110" Margin="0,0,8,0" Click="SavePdf_Click"/>
                <Button Content="Excel Kaydet" Width="110" Margin="0,0,8,0" Click="SaveExcel_Click"/>
                <Button Content="Kapat"        Width="80"                   Click="Close_Click"/>
            </StackPanel>
        </Border>

        <!-- Rapor içeriği -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Başlık -->
                <TextBlock Text="Finansal Rapor"
                           FontSize="18" FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="DateRangeText"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,12"/>
                <Separator Margin="0,0,0,12"/>

                <!-- Para Birimi Özet Kartları -->
                <TextBlock Text="Para Birimi Özeti"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <UniformGrid Columns="3" Margin="0,0,0,16">

                    <!-- TL -->
                    <GroupBox Header="TL" Margin="0,0,6,0" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Toplam Giriş:" Margin="0,2"/>
                            <TextBlock x:Name="TlInflowText"  Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Foreground="#2E7D32" Margin="4,2,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Toplam Çıkış:" Margin="0,2"/>
                            <TextBlock x:Name="TlOutflowText" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Foreground="#C62828" Margin="4,2,0,2"/>
                            <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Net Bakiye:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock x:Name="TlNetText"     Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="4,2,0,2"/>
                        </Grid>
                    </GroupBox>

                    <!-- USD -->
                    <GroupBox Header="USD" Margin="3,0,3,0" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Toplam Giriş:" Margin="0,2"/>
                            <TextBlock x:Name="UsdInflowText"  Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Foreground="#2E7D32" Margin="4,2,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Toplam Çıkış:" Margin="0,2"/>
                            <TextBlock x:Name="UsdOutflowText" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Foreground="#C62828" Margin="4,2,0,2"/>
                            <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Net Bakiye:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock x:Name="UsdNetText"     Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="4,2,0,2"/>
                        </Grid>
                    </GroupBox>

                    <!-- EUR -->
                    <GroupBox Header="EUR" Margin="6,0,0,0" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Toplam Giriş:" Margin="0,2"/>
                            <TextBlock x:Name="EurInflowText"  Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Foreground="#2E7D32" Margin="4,2,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Toplam Çıkış:" Margin="0,2"/>
                            <TextBlock x:Name="EurOutflowText" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Foreground="#C62828" Margin="4,2,0,2"/>
                            <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Net Bakiye:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock x:Name="EurNetText"     Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="4,2,0,2"/>
                        </Grid>
                    </GroupBox>

                </UniformGrid>

                <!-- İşlem Türü Tablosu -->
                <TextBlock Text="İşlem Türü Bazında Toplam"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <DataGrid x:Name="TypeDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F5F5F5"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="İşlem Türü"
                                            Binding="{Binding TypeDisplay}"
                                            Width="120"/>
                        <DataGridTextColumn Header="TL Tutar"
                                            Binding="{Binding TryAmount, StringFormat=N2}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TL Adet"
                                            Binding="{Binding TryCount}"
                                            Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="USD Tutar"
                                            Binding="{Binding UsdAmount, StringFormat=N2}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="USD Adet"
                                            Binding="{Binding UsdCount}"
                                            Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EUR Tutar"
                                            Binding="{Binding EurAmount, StringFormat=N2}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EUR Adet"
                                            Binding="{Binding EurCount}"
                                            Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
